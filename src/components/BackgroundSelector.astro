---
---

<div class="bg-selector" id="bgSelector">
  <button class="bg-btn active" data-bg="0" title="Fireflies">
    <svg viewBox="0 0 16 16" fill="currentColor">
      <circle cx="4" cy="4" r="2" opacity="0.8"/>
      <circle cx="12" cy="6" r="1.5" opacity="0.6"/>
      <circle cx="6" cy="12" r="1" opacity="0.7"/>
      <circle cx="10" cy="10" r="2" opacity="0.5"/>
      <circle cx="2" cy="10" r="1" opacity="0.6"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="1" title="Matrix">
    <svg viewBox="0 0 16 16" fill="currentColor">
      <text x="1" y="4" font-size="4">ア</text>
      <text x="1" y="8" font-size="4">イ</text>
      <text x="1" y="12" font-size="4">ウ</text>
      <text x="8" y="4" font-size="4">エ</text>
      <text x="8" y="8" font-size="4">オ</text>
      <text x="8" y="12" font-size="4">カ</text>
    </svg>
  </button>
  <button class="bg-btn" data-bg="2" title="Starfield">
    <svg viewBox="0 0 16 16" fill="currentColor">
      <circle cx="4" cy="3" r="1" opacity="0.9"/>
      <circle cx="12" cy="5" r="1.5" opacity="0.7"/>
      <circle cx="8" cy="8" r="2" opacity="1"/>
      <circle cx="3" cy="11" r="1" opacity="0.6"/>
      <circle cx="13" cy="13" r="1" opacity="0.8"/>
      <circle cx="6" cy="14" r="0.5" opacity="0.5"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="3" title="Waves">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M0 8 Q4 4, 8 8 T16 8" opacity="0.8"/>
      <path d="M0 10 Q4 6, 8 10 T16 10" opacity="0.5"/>
      <path d="M0 12 Q4 8, 8 12 T16 12" opacity="0.3"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="4" title="Minecraft">
    <svg viewBox="0 0 16 16">
      <rect x="2" y="2" width="12" height="12" fill="#4ade80" opacity="0.9"/>
      <rect x="2" y="2" width="12" height="3" fill="#6db35f"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="5" title="Code">
    <svg viewBox="0 0 16 16" fill="currentColor">
      <text x="1" y="5" font-size="3" font-family="monospace" fill="#a855f7">&lt;/&gt;</text>
      <text x="1" y="10" font-size="3" font-family="monospace" fill="#06b6d4">{ }</text>
      <text x="1" y="15" font-size="3" font-family="monospace" fill="#fff">( )</text>
    </svg>
  </button>
  <button class="bg-btn" data-bg="6" title="Blobs">
    <svg viewBox="0 0 16 16">
      <ellipse cx="6" cy="6" rx="5" ry="4" fill="#a855f7" opacity="0.5"/>
      <ellipse cx="10" cy="10" rx="4" ry="5" fill="#ec4899" opacity="0.4"/>
      <ellipse cx="8" cy="8" rx="3" ry="3" fill="#3b82f6" opacity="0.3"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="7" title="Noise">
    <svg viewBox="0 0 16 16">
      <rect x="1" y="1" width="2" height="2" fill="#333" opacity="0.8"/>
      <rect x="4" y="1" width="3" height="2" fill="#555" opacity="0.6"/>
      <rect x="8" y="1" width="2" height="2" fill="#222" opacity="0.9"/>
      <rect x="11" y="1" width="4" height="2" fill="#444" opacity="0.7"/>
      <rect x="1" y="4" width="4" height="2" fill="#666" opacity="0.5"/>
      <rect x="6" y="4" width="2" height="2" fill="#333" opacity="0.8"/>
      <rect x="9" y="4" width="3" height="2" fill="#555" opacity="0.6"/>
      <rect x="1" y="7" width="2" height="2" fill="#444" opacity="0.7"/>
      <rect x="4" y="7" width="3" height="2" fill="#333" opacity="0.9"/>
      <rect x="8" y="7" width="2" height="2" fill="#666" opacity="0.5"/>
      <rect x="11" y="7" width="4" height="2" fill="#444" opacity="0.8"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="8" title="Aurora">
    <svg viewBox="0 0 16 16">
      <path d="M0 6 Q4 2, 8 6 T16 6" stroke="#10b981" stroke-width="2" fill="none" opacity="0.6"/>
      <path d="M0 8 Q4 4, 8 8 T16 8" stroke="#a855f7" stroke-width="2" fill="none" opacity="0.4"/>
      <path d="M0 10 Q4 6, 8 10 T16 10" stroke="#3b82f6" stroke-width="2" fill="none" opacity="0.3"/>
    </svg>
  </button>
  <button class="bg-btn" data-bg="9" title="Falling Blocks">
    <svg viewBox="0 0 16 16">
      <rect x="2" y="2" width="5" height="5" fill="#4ade80" opacity="0.8" transform="rotate(15 4.5 4.5)"/>
      <rect x="9" y="5" width="5" height="5" fill="#3b82f6" opacity="0.8" transform="rotate(-10 11.5 7.5)"/>
      <rect x="4" y="9" width="5" height="5" fill="#fbbf24" opacity="0.8" transform="rotate(20 6.5 11.5)"/>
    </svg>
  </button>
</div>

<script>
  const selector = document.getElementById('bgSelector');
  const buttons = selector?.querySelectorAll('.bg-btn');
  
  function setBackground(index: number) {
    localStorage.setItem('selectedBackground', String(index));
    
    buttons?.forEach((btn, i) => {
      btn.classList.toggle('active', i === index);
    });
    
    window.dispatchEvent(new CustomEvent('backgroundChange', { detail: { index } }));
  }
  
  buttons?.forEach((btn, i) => {
    btn.addEventListener('click', () => setBackground(i));
  });
  
  const saved = localStorage.getItem('selectedBackground');
  if (saved) {
    const index = parseInt(saved);
    setBackground(index);
  }
</script>
