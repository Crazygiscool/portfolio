<div class="background-container" id="matrix-container">
  <canvas id="matrix-canvas"></canvas>
</div>

<script>
  class MatrixRain {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private columns: Array<{x: number; y: number; chars: string[]; speed: number}> = [];
    private animationId: number = 0;
    private chars = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789';

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.resize();
      this.init();
      window.addEventListener('resize', () => this.resize());
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private init() {
      const fontSize = 14;
      const columnCount = Math.floor(this.canvas.width / fontSize);
      
      this.columns = [];
      for (let i = 0; i < columnCount; i++) {
        this.columns.push({
          x: i * fontSize,
          y: Math.random() * this.canvas.height - this.canvas.height,
          chars: [],
          speed: Math.random() * 3 + 2
        });
        const charCount = Math.floor(Math.random() * 20) + 10;
        for (let j = 0; j < charCount; j++) {
          this.columns[i].chars.push(this.chars[Math.floor(Math.random() * this.chars.length)]);
        }
      }
      this.animate();
    }

    private animate = () => {
      this.ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      this.ctx.font = '14px monospace';

      this.columns.forEach(col => {
        for (let i = 0; i < col.chars.length; i++) {
          const charY = col.y + i * 14;
          if (charY < this.canvas.height && charY > 0) {
            const alpha = 1 - i / col.chars.length;
            if (i === 0) {
              this.ctx.fillStyle = '#fff';
              this.ctx.globalAlpha = 1;
            } else {
              this.ctx.fillStyle = '#0f0';
              this.ctx.globalAlpha = alpha * 0.8;
            }
            this.ctx.fillText(col.chars[i], col.x, charY);
          }
        }

        col.y += col.speed;

        if (col.y - col.chars.length * 14 > this.canvas.height) {
          col.y = -col.chars.length * 14;
          col.speed = Math.random() * 3 + 2;
          for (let i = 0; i < col.chars.length; i++) {
            col.chars[i] = this.chars[Math.floor(Math.random() * this.chars.length)];
          }
        }
      });

      this.ctx.globalAlpha = 1;
      this.animationId = requestAnimationFrame(this.animate);
    }

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  const container = document.getElementById('matrix-container');
  if (container) {
    const canvas = document.getElementById('matrix-canvas') as HTMLCanvasElement;
    if (canvas) {
      const matrix = new MatrixRain(canvas);
      (window as any).__matrix = matrix;
    }
  }
</script>

<style>
  .background-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #000;
  }

  #matrix-canvas {
    width: 100%;
    height: 100%;
  }
</style>
