---
---

<div class="background-container" id="starfield-container">
  <canvas id="starfield-canvas"></canvas>
</div>

<script>
  class Starfield {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private stars: Array<{x: number; y: number; z: number; color: string}> = [];
    private animationId: number = 0;
    private speed = 2;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.resize();
      this.init();
      window.addEventListener('resize', () => this.resize());
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private init() {
      const colors = ['#fff', '#a855f7', '#ec4899', '#3b82f6', '#fbbf24'];
      for (let i = 0; i < 400; i++) {
        this.stars.push({
          x: Math.random() * this.canvas.width - this.canvas.width / 2,
          y: Math.random() * this.canvas.height - this.canvas.height / 2,
          z: Math.random() * 1000,
          color: colors[Math.floor(Math.random() * colors.length)]
        });
      }
      this.animate();
    }

    private animate = () => {
      this.ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      const cx = this.canvas.width / 2;
      const cy = this.canvas.height / 2;

      this.stars.forEach(star => {
        star.z -= this.speed;
        if (star.z <= 0) {
          star.z = 1000;
          star.x = Math.random() * this.canvas.width - cx;
          star.y = Math.random() * this.canvas.height - cy;
        }

        const sx = (star.x / star.z) * 300 + cx;
        const sy = (star.y / star.z) * 300 + cy;
        const size = (1 - star.z / 1000) * 3;
        const brightness = 1 - star.z / 1000;

        if (sx >= 0 && sx <= this.canvas.width && sy >= 0 && sy <= this.canvas.height) {
          this.ctx.beginPath();
          this.ctx.fillStyle = star.color;
          this.ctx.globalAlpha = brightness;
          this.ctx.arc(sx, sy, size, 0, Math.PI * 2);
          this.ctx.fill();
          
          if (brightness > 0.7) {
            this.ctx.beginPath();
            this.ctx.fillStyle = '#fff';
            this.ctx.arc(sx, sy, size * 0.5, 0, Math.PI * 2);
            this.ctx.fill();
          }
        }
      });

      this.ctx.globalAlpha = 1;
      this.animationId = requestAnimationFrame(this.animate);
    }

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  const container = document.getElementById('starfield-container');
  if (container) {
    const canvas = document.getElementById('starfield-canvas') as HTMLCanvasElement;
    if (canvas) {
      const starfield = new Starfield(canvas);
      (window as any).__starfield = starfield;
    }
  }
</script>

<style>
  .background-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(ellipse at center, #0a0a1a 0%, #0a0a0f 100%);
  }

  #starfield-canvas {
    width: 100%;
    height: 100%;
  }
</style>
