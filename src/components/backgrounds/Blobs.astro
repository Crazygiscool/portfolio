---

<div class="background-container" id="blobs-container">
  <canvas id="blobs-canvas"></canvas>
</div>

<script>
  class Blobs {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private blobs: Array<{x: number; y: number; radius: number; vx: number; vy: number; color: string; phase: number}> = [];
    private animationId: number = 0;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.resize();
      this.init();
      window.addEventListener('resize', () => this.resize());
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private init() {
      const colors = [
        'rgba(168, 85, 247, 0.3)',
        'rgba(236, 72, 153, 0.25)',
        'rgba(59, 130, 246, 0.25)',
        'rgba(16, 185, 129, 0.2)',
        'rgba(251, 191, 36, 0.2)'
      ];

      for (let i = 0; i < 6; i++) {
        this.blobs.push({
          x: Math.random() * this.canvas.width,
          y: Math.random() * this.canvas.height,
          radius: Math.random() * 200 + 150,
          vx: (Math.random() - 0.5) * 0.5,
          vy: (Math.random() - 0.5) * 0.5,
          color: colors[i % colors.length],
          phase: Math.random() * Math.PI * 2
        });
      }
      this.animate();
    }

    private animate = () => {
      this.ctx.fillStyle = 'rgba(10, 10, 15, 0.03)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      this.blobs.forEach(blob => {
        blob.x += blob.vx;
        blob.y += blob.vy;
        blob.phase += 0.01;

        if (blob.x < -blob.radius) blob.x = this.canvas.width + blob.radius;
        if (blob.x > this.canvas.width + blob.radius) blob.x = -blob.radius;
        if (blob.y < -blob.radius) blob.y = this.canvas.height + blob.radius;
        if (blob.y > this.canvas.height + blob.radius) blob.y = -blob.radius;

        const dynamicRadius = blob.radius * (1 + Math.sin(blob.phase) * 0.1);

        const gradient = this.ctx.createRadialGradient(
          blob.x, blob.y, 0,
          blob.x, blob.y, dynamicRadius
        );
        gradient.addColorStop(0, blob.color);
        gradient.addColorStop(0.5, blob.color.replace(/[\d.]+\)$/, '0.1)'));
        gradient.addColorStop(1, 'transparent');

        this.ctx.fillStyle = gradient;
        this.ctx.beginPath();
        this.ctx.arc(blob.x, blob.y, dynamicRadius, 0, Math.PI * 2);
        this.ctx.fill();
      });

      this.animationId = requestAnimationFrame(this.animate);
    }

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  const container = document.getElementById('blobs-container');
  if (container) {
    const canvas = document.getElementById('blobs-canvas') as HTMLCanvasElement;
    if (canvas) {
      const blobs = new Blobs(canvas);
      (window as any).__blobs = blobs;
    }
  }
</script>

<style>
  .background-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: radial-gradient(ellipse at center, #1a0a2e 0%, #0a0a0f 100%);
  }

  #blobs-canvas {
    width: 100%;
    height: 100%;
  }
</style>
