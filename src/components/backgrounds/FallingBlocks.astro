---
---

<div class="background-container" id="falling-blocks-container">
  <canvas id="falling-blocks-canvas"></canvas>
</div>

<script>
  class FallingBlocks {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private blocks: Array<{x: number; y: number; size: number; speed: number; texture: string; rotation: number; rotSpeed: number}> = [];
    private animationId: number = 0;
    private textures: Record<string, HTMLImageElement> = {};
    private loaded = 0;
    private total = 4;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.resize();
      this.loadTextures();
      window.addEventListener('resize', () => this.resize());
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private loadTextures() {
      const urls = {
        grass: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/grass_block_top.png',
        emerald: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/emerald_block.png',
        diamond: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/diamond_block.png',
        gold: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/gold_block.png'
      };

      Object.entries(urls).forEach(([name, url]) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
          this.textures[name] = img;
          this.loaded++;
          if (this.loaded >= this.total) {
            this.spawnInitial();
            this.animate();
          }
        };
        img.src = url;
      });
    }

    private spawnInitial() {
      for (let i = 0; i < 30; i++) {
        this.spawnBlock();
      }
    }

    private spawnBlock() {
      const textureNames = ['grass', 'emerald', 'diamond', 'gold'];
      const texture = textureNames[Math.floor(Math.random() * textureNames.length)];
      const size = Math.random() * 30 + 20;
      
      this.blocks.push({
        x: Math.random() * this.canvas.width,
        y: -size,
        size,
        speed: Math.random() * 2 + 1,
        texture,
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.02
      });
    }

    private animate = () => {
      this.ctx.fillStyle = 'rgba(10, 10, 15, 0.15)';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      for (let i = this.blocks.length - 1; i >= 0; i--) {
        const block = this.blocks[i];
        block.y += block.speed;
        block.rotation += block.rotSpeed;

        if (block.y > this.canvas.height + block.size) {
          this.blocks.splice(i, 1);
          this.spawnBlock();
          continue;
        }

        if (this.textures[block.texture]) {
          this.ctx.save();
          this.ctx.translate(block.x + block.size / 2, block.y + block.size / 2);
          this.ctx.rotate(block.rotation);
          this.ctx.globalAlpha = 0.4;
          this.ctx.imageSmoothingEnabled = false;
          this.ctx.drawImage(
            this.textures[block.texture],
            -block.size / 2,
            -block.size / 2,
            block.size,
            block.size
          );
          this.ctx.restore();
        }
      }

      this.ctx.globalAlpha = 1;
      this.animationId = requestAnimationFrame(this.animate);
    }

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  const container = document.getElementById('falling-blocks-container');
  if (container) {
    const canvas = document.getElementById('falling-blocks-canvas') as HTMLCanvasElement;
    if (canvas) {
      const fallingBlocks = new FallingBlocks(canvas);
      (window as any).__fallingBlocks = fallingBlocks;
    }
  }
</script>

<style>
  .background-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #0a0a0f;
  }

  #falling-blocks-canvas {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
</style>
