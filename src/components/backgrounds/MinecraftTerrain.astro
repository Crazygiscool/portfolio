---
---

<div class="background-container" id="mc-terrain-container">
  <canvas id="mc-terrain-canvas"></canvas>
</div>

<script>
  class MinecraftTerrain {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private animationId: number = 0;
    private offset = 0;
    private blockSize = 16;
    private textures: Record<string, ImageData> = {};
    private loaded = 0;
    private total = 6;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.resize();
      this.loadTextures();
      window.addEventListener('resize', () => this.resize());
    }

    private resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
    }

    private loadTextures() {
      const urls = {
        stone: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/stone.png',
        dirt: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/dirt.png',
        grass_top: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/grass_block_top.png',
        grass_side: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/grass_block_side.png',
        oak_log: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/oak_log.png',
        oak_leaves: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/oak_leaves.png'
      };

      Object.entries(urls).forEach(([name, url]) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = () => {
          const tempCanvas = document.createElement('canvas');
          tempCanvas.width = 16;
          tempCanvas.height = 16;
          const tempCtx = tempCanvas.getContext('2d')!;
          tempCtx.drawImage(img, 0, 0);
          this.textures[name] = tempCtx.getImageData(0, 0, 16, 16);
          this.loaded++;
          if (this.loaded >= this.total) {
            this.animate();
          }
        };
        img.src = url;
      });
    }

    private drawBlock(x: number, y: number, texture: ImageData, opacity = 1) {
      const tempCanvas = document.createElement('canvas');
      tempCanvas.width = 16;
      tempCanvas.height = 16;
      const tempCtx = tempCanvas.getContext('2d')!;
      tempCtx.putImageData(texture, 0, 0);
      this.ctx.globalAlpha = opacity;
      this.ctx.imageSmoothingEnabled = false;
      this.ctx.drawImage(tempCanvas, Math.floor(x), Math.floor(y), this.blockSize, this.blockSize);
      this.ctx.globalAlpha = 1;
    }

    private animate = () => {
      this.ctx.fillStyle = '#87ceeb';
      this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

      const cols = Math.ceil(this.canvas.width / this.blockSize) + 2;
      const rows = Math.ceil(this.canvas.height / this.blockSize) + 2;

      for (let x = 0; x < cols; x++) {
        for (let y = 0; y < rows; y++) {
          const worldX = x + Math.floor(this.offset / this.blockSize);
          const px = x * this.blockSize - (this.offset % this.blockSize);
          const py = y * this.blockSize;

          const heightFromBottom = rows - y;
          let texture: ImageData;
          let opacity = 1;

          if (heightFromBottom <= 2) {
            texture = this.textures.dirt;
          } else if (heightFromBottom <= 5) {
            texture = this.textures.stone;
          } else if (heightFromBottom === 6) {
            texture = this.textures.grass_top;
          } else if (heightFromBottom === 7) {
            texture = this.textures.grass_side;
          } else if (heightFromBottom === 8) {
            const hash = (worldX * 7 + y * 13) % 10;
            texture = hash > 6 ? this.textures.oak_log : this.textures.oak_leaves;
          } else if (heightFromBottom <= 10) {
            const hash = (worldX * 11 + y * 17) % 10;
            texture = hash > 4 ? this.textures.oak_leaves : this.textures.oak_log;
          } else {
            texture = this.textures.oak_leaves;
            opacity = 0.6;
          }

          if (texture) {
            this.drawBlock(px, py, texture, opacity);
          }
        }
      }

      this.offset += 0.5;
      this.animationId = requestAnimationFrame(this.animate);
    }

    public destroy() {
      cancelAnimationFrame(this.animationId);
    }
  }

  const container = document.getElementById('mc-terrain-container');
  if (container) {
    const canvas = document.getElementById('mc-terrain-canvas') as HTMLCanvasElement;
    if (canvas) {
      const terrain = new MinecraftTerrain(canvas);
      (window as any).__mcTerrain = terrain;
    }
  }
</script>

<style>
  .background-container {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  #mc-terrain-canvas {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }
</style>
