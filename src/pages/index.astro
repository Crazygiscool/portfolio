          <circle cx="4" cy="3" r="1" opacity="0.9"/>
          <circle cx="12" cy="5" r="1.5" opacity="0.7"/>
          <circle cx="8" cy="8" r="2" opacity="1"/>
          <circle cx="3" cy="11" r="1" opacity="0.6"/>
          <circle cx="13" cy="13" r="1" opacity="0.8"/>
