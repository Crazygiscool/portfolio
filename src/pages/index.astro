---
import '../styles/global.css';

interface WakaTimeStatsData {
  range: string;
  human_readable_range: string;
  total_seconds: number;
  total_seconds_including_other_language: number;
  human_readable_total: string;
  human_readable_total_including_other_language: string;
  daily_average: number;
  daily_average_including_other_language: number;
  human_readable_daily_average: string;
  human_readable_daily_average_including_other_language: string;
  holidays: number;
  days_including_holidays: number;
  days_minus_holidays: number;
  is_up_to_date: boolean;
  is_including_today: boolean;
  is_coding_activity_visible: boolean;
  is_other_usage_visible: boolean;
  start: string;
  end: string;
  timezone: string;
  best_day: {
    date: string;
    text: string;
    total_seconds: number;
  } | null;
  ai_additions: number;
  ai_deletions: number;
  human_additions: number;
  human_deletions: number;
  languages: WakaTimeStatItem[];
  editors: WakaTimeStatItem[];
  operating_systems: WakaTimeStatItem[];
  categories: WakaTimeStatItem[];
  projects: WakaTimeStatItem[];
  dependencies: WakaTimeStatItem[];
  machines: WakaTimeMachineItem[];
}

interface WakaTimeStatItem {
  name: string;
  total_seconds: number;
  percent: number;
  digital: string;
  text: string;
  hours: number;
  minutes: number;
  seconds: number;
}

interface WakaTimeMachineItem extends WakaTimeStatItem {
  machine_name_id: string;
}

interface WakaTimeAllTimeData {
  daily_average: number;
  decimal: string;
  digital: string;
  is_up_to_date: boolean;
  percent_calculated: number;
  range: {
    end: string;
    end_date: string;
    end_text: string;
    start: string;
    start_date: string;
    start_text: string;
    timezone: string;
  };
  text: string;
  timeout: number;
  total_seconds: number;
}

const colorMap: Record<string, string> = {
  Java: '#ea580c',
  Python: '#eab308',
  JavaScript: '#eab308',
  TypeScript: '#3b82f6',
  Dart: '#06b6d4',
  GDScript: '#059669',
  Lua: '#000080',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Shell: '#89e051',
};

const res = await fetch('https://api.github.com/users/crazygiscool/repos?sort=stars&per_page=100');
const repos = await res.json();

const projects = repos
  .filter((r: any) => !r.fork && r.description)
  .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count)
  .slice(0, 6)
  .map((r: any) => ({
    name: r.name,
    description: r.description,
    language: r.language || 'Code',
    stars: r.stargazers_count,
    url: r.html_url,
    color: colorMap[r.language] || '#a855f7',
  }));

const contributionsRes = await fetch('https://github-contributions-api.jogruber.de/v4/crazygiscool');
const contributions = contributionsRes.ok ? await contributionsRes.json() : { contributions: [], totalContributions: 0 };

const contributionsData = contributions.contributions || [];

const today = new Date();
const oneYearAgo = new Date();
oneYearAgo.setFullYear(oneYearAgo.getFullYear() - 1);

const startDate = new Date(oneYearAgo);
startDate.setDate(startDate.getDate() - startDate.getDay());

const endDate = new Date(today);
endDate.setDate(endDate.getDate() + (6 - endDate.getDay()));

const totalContributions = contributionsData.reduce((sum: number, day: any) => sum + day.count, 0);

const displayWeeks: ({ date: string; count: number; level: number } | null)[][] = [];

let currentWeek: ({ date: string; count: number; level: number } | null)[] = [null, null, null, null, null, null, null];

for (let d = new Date(startDate); d <= endDate; d.setDate(d.getDate() + 1)) {
  const dayOfWeek = d.getDay();
  
  if (dayOfWeek === 0 && currentWeek.some(w => w !== null)) {
    displayWeeks.push(currentWeek);
    currentWeek = [null, null, null, null, null, null, null];
  }
  
  const dateStr = d.toISOString().split('T')[0];
  const existing = contributionsData.find((c: any) => c.date === dateStr);
  const count = (existing && existing.count > 0) ? existing.count : 0;
  
  if (count > 0) {
    let level = 1;
    if (count <= 2) level = 1;
    else if (count <= 5) level = 2;
    else if (count <= 10) level = 3;
    else if (count > 10) level = 4;
    currentWeek[dayOfWeek] = { date: dateStr, count, level };
  }
}

if (currentWeek.some(w => w !== null)) {
  displayWeeks.push(currentWeek);
}

const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const monthLabels: { month: string; weekIndex: number }[] = [];
let lastMonth = -1;
displayWeeks.forEach((week, i) => {
  const firstDay = week.find(d => d !== null);
  if (firstDay && firstDay.date) {
    const month = new Date(firstDay.date).getMonth();
    if (month !== lastMonth) {
      monthLabels.push({ month: monthNames[month], weekIndex: i });
      lastMonth = month;
    }
  }
});

const yearsContributions = Math.max(...contributionsData.reduce((acc: number[][], y: any) => {
  if (y.weeks) {
    y.weeks.forEach((w: any) => {
      w.contributions.forEach((c: any) => {
        if (c.date && c.date.startsWith(new Date().getFullYear().toString())) {
          acc[0] = (acc[0] || 0) + c.count;
        }
      });
    });
  }
  return acc;
}, [0]), 0);

const thisYearContributions = yearsContributions || totalContributions;

const wakaKey = import.meta.env.WAKATIME_API_KEY;
let wakaStats: { data: WakaTimeStatsData } | null = null;
let wakaAllTimeStats: { data: WakaTimeAllTimeData } | null = null;

if (wakaKey) {
  const wakaRes = await fetch('https://wakatime.com/api/v1/users/current/stats/last_7_days', {
    headers: { 'Authorization': `Basic ${btoa(wakaKey)}` }
  });
  wakaStats = await wakaRes.json();
  
  const wakaAllRes = await fetch('https://wakatime.com/api/v1/users/current/all_time_since_today', {
    headers: { 'Authorization': `Basic ${btoa(wakaKey)}` }
  });
  wakaAllTimeStats = await wakaAllRes.json();
}

const starredRes = await fetch('https://api.github.com/users/crazygiscool/starred?per_page=30&sort=updated');
const starredRepos = starredRes.ok ? await starredRes.json() : [];

const skills = [
  { name: 'Java', level: 85, color: '#ea580c' },
  { name: 'GDScript', level: 80, color: '#059669' },
  { name: 'Dart', level: 60, color: '#06b6d4' },
  { name: 'Python', level: 70, color: '#eab308' },
  { name: 'TypeScript', level: 65, color: '#3b82f6' },
  { name: 'JavaScript', level: 70, color: '#eab308' },
];
---

