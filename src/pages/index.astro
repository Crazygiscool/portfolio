      <button class="bg-btn" data-bg="5" title="Code">
        <svg viewBox="0 0 16 16" fill="currentColor">
          <text x="1" y="5" font-size="3" font-family="monospace" fill="#a855f7">&lt;/&gt;</text>
          <text x="1" y="10" font-size="3" font-family="monospace" fill="#06b6d4">{ }</text>
