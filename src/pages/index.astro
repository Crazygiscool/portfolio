          <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
            <a
              href="mailto:crazygiscool@proton.me"
              class="inline-flex items-center gap-2 rounded-lg border border-accent/30 bg-accent/10 px-5 py-3 font-mono text-sm font-medium text-accent hover:bg-accent/20 transition-all duration-150"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              crazygiscool@proton.me
