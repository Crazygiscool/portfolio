      </section>

      {wakaStats && wakaStats.data && (
        <section id="wakatime" class="section">
          <div class="container">
            <h2>WakaTime</h2>
            <p class="section-subtitle">Coding statistics • {wakaStats.data.human_readable_range}</p>
            
            <div class="waka-full-grid">
              <div class="waka-card waka-summary">
                <div class="waka-summary-stats">
                  <div class="waka-stat-inline">
                    <span class="waka-stat-value">{wakaStats.data.human_readable_total}</span>
                    <span class="waka-stat-label">Total Time</span>
                  </div>
                  <div class="waka-stat-inline">
                    <span class="waka-stat-value">{wakaStats.data.human_readable_daily_average}</span>
                    <span class="waka-stat-label">Daily Avg</span>
                  </div>
                  <div class="waka-stat-inline">
                    <span class="waka-stat-value">{wakaStats.data.best_day?.text || '-'}</span>
                    <span class="waka-stat-label">Best Day</span>
                  </div>
                  <div class="waka-stat-inline">
                    <span class="waka-stat-value">{wakaStats.data.days_minus_holidays || 0}</span>
                    <span class="waka-stat-label">Active Days</span>
                  </div>
                </div>
              </div>

              <div class="waka-card waka-all-time">
                <h3>All Time Since Today</h3>
                <div class="waka-stats-grid">
                  <div class="waka-stat-box">
                    <span class="waka-stat-value">{wakaAllTimeStats?.data?.text || '-'}</span>
                    <span class="waka-stat-label">Total Time</span>
                  </div>
                  <div class="waka-stat-box">
                    <span class="waka-stat-value">{wakaAllTimeStats?.data?.digital || '-'}</span>
                    <span class="waka-stat-label">Digital</span>
                  </div>
                  <div class="waka-stat-box">
                    <span class="waka-stat-value">{Math.round((wakaAllTimeStats?.data?.daily_average || 0) / 3600 * 10) / 10}h</span>
                    <span class="waka-stat-label">Daily Avg</span>
                  </div>
                  <div class="waka-stat-box">
                    <span class="waka-stat-value">{wakaAllTimeStats?.data?.range?.start_date || '-'}</span>
                    <span class="waka-stat-label">Since</span>
                  </div>
                </div>
              </div>
            </div>

              <div class="waka-tabs">
                <div class="waka-tab-buttons">
                  <button class="waka-tab-btn active" data-tab="languages">Languages</button>
                  <button class="waka-tab-btn" data-tab="editors">Editors</button>
                  <button class="waka-tab-btn" data-tab="os">OS</button>
                  <button class="waka-tab-btn" data-tab="categories">Categories</button>
                </div>

                <div class="waka-tab-content active" id="tab-languages">
                  <div class="waka-card waka-pie-card">
                    <script id="langData" type="application/json" set:html={JSON.stringify(wakaStats.data.languages.slice(0, 8))}></script>
                    <div class="pie-wrapper">
                      <div class="pie-container" id="pieContainer">
                        <div 
                          class="pie-chart"
                          id="pieChart"
                          style={(() => {
                            const topLangs = wakaStats.data.languages.slice(0, 8);
                            const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
                            let gradient = '';
                            let currentDeg = 0;
                            topLangs.forEach((lang, i) => {
                              const deg = (lang.percent / 100) * 360;
                              gradient += `${colors[i % colors.length]} ${currentDeg}deg ${currentDeg + deg}deg, `;
                              currentDeg += deg;
                            });
                            return `background: conic-gradient(${gradient.slice(0, -2)});`;
                          })()}
                        >
                          <div class="pie-center">
                            <span class="pie-center-text" id="pieCenterText">{wakaStats.data.languages[0]?.name || '-'}</span>
                            <span class="pie-center-time" id="pieCenterTime">{wakaStats.data.languages[0]?.text || '-'}</span>
                            <span class="pie-center-percent" id="pieCenterPercent">{wakaStats.data.languages[0]?.percent.toFixed(1) || '0'}%</span>
                          </div>
                        </div>
                        <div class="pie-tooltip" id="pieTooltip"></div>
                      </div>
                      <div class="pie-legend">
                        {wakaStats.data.languages.slice(0, 8).map((lang, i) => {
                          const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
                          return (
                            <div class="pie-legend-item" data-index={i}>
                              <span class="pie-legend-color" style={`background: ${colors[i % colors.length]}`}></span>
                              <span class="pie-legend-name">{lang.name}</span>
                              <span class="pie-legend-percent">{lang.percent.toFixed(1)}%</span>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  </div>
                </div>

                <div class="waka-tab-content" id="tab-editors">
                  <div class="waka-card">
                    <div class="waka-blocks-grid">
                      {wakaStats.data.editors && wakaStats.data.editors.length > 0 ? (
                        wakaStats.data.editors.map((editor, i) => {
                          const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
                          return (
                            <div class="waka-block" style={`--block-color: ${colors[i % colors.length]}`}>
                              <div class="waka-block-header">
                                <span class="waka-block-name">{editor.name}</span>
                                <span class="waka-block-percent">{editor.percent.toFixed(1)}%</span>
                              </div>
                              <div class="waka-block-bar">
                                <div class="waka-block-fill" style={`width: ${editor.percent}%`}></div>
                              </div>
                              <span class="waka-block-time">{editor.text}</span>
                            </div>
                          );
                        })
                      ) : (
                        <p class="text-gray-500">No editor data</p>
                      )}
                    </div>
                  </div>
                </div>

                <div class="waka-tab-content" id="tab-os">
                  <div class="waka-card">
                    <div class="waka-blocks-grid">
                      {wakaStats.data.operating_systems && wakaStats.data.operating_systems.length > 0 ? (
                        wakaStats.data.operating_systems.map((os, i) => {
                          const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
                          return (
                            <div class="waka-block" style={`--block-color: ${colors[i % colors.length]}`}>
                              <div class="waka-block-header">
                                <span class="waka-block-name">{os.name}</span>
                                <span class="waka-block-percent">{os.percent.toFixed(1)}%</span>
                              </div>
                              <div class="waka-block-bar">
                                <div class="waka-block-fill" style={`width: ${os.percent}%`}></div>
                              </div>
                              <span class="waka-block-time">{os.text}</span>
                            </div>
                          );
                        })
                      ) : (
                        <p class="text-gray-500">No OS data</p>
                      )}
                    </div>
                  </div>
                </div>

                <div class="waka-tab-content" id="tab-categories">
                  <div class="waka-card">
                    <div class="waka-blocks-grid">
                      {wakaStats.data.categories && wakaStats.data.categories.length > 0 ? (
                        wakaStats.data.categories.map((cat, i) => {
                          const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
                          return (
                            <div class="waka-block" style={`--block-color: ${colors[i % colors.length]}`}>
                              <div class="waka-block-header">
                                <span class="waka-block-name">{cat.name}</span>
                                <span class="waka-block-percent">{cat.percent.toFixed(1)}%</span>
                              </div>
                              <div class="waka-block-bar">
                                <div class="waka-block-fill" style={`width: ${cat.percent}%`}></div>
                              </div>
                              <span class="waka-block-time">{cat.text}</span>
                            </div>
                          );
                        })
                      ) : (
                        <p class="text-gray-500">No category data</p>
                      )}
                    </div>
                  </div>
                </div>
              </div>
          </div>
        </section>
      )}

      <section id="contact" class="contact">
        <div class="container">
          <h2>Get in Touch</h2>
          <p class="section-subtitle">Feel free to reach out</p>
          <div class="contact-links">
            <a href="mailto:crazygiscool@proton.me" class="contact-btn">
              crazygiscool@proton.me
            </a>
            <a href="https://github.com/crazygiscool" class="contact-btn">
              GitHub
            </a>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <p>© {new Date().getFullYear()} Crazygiscool</p>
    </footer>
    
    <script>
      const colors = ['#a855f7', '#ec4899', '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#06b6d4', '#8b5cf6'];
      
      function initBackgroundSelector() {
        const selector = document.getElementById('bgSelector');
        const buttons = selector?.querySelectorAll('.bg-btn');
        
        function showBackground(index: number) {
          localStorage.setItem('selectedBackground', String(index));
          
          document.querySelectorAll('.bg-layer').forEach((layer, i) => {
            layer.classList.toggle('active', i === index);
          });
          
          buttons?.forEach((btn, i) => {
            btn.classList.toggle('active', i === index);
          });
          
          const canvases = document.querySelectorAll('canvas');
          canvases.forEach(canvas => {
            const ctx = canvas.getContext('2d');
            if (ctx) {
              const data = (canvas as any).animationData;
              if (data && data.running) {
                data.running = i === index;
              }
            }
          });
        }
        
        buttons?.forEach((btn, i) => {
          btn.addEventListener('click', () => showBackground(i));
        });
        
        window.addEventListener('backgroundChange', ((e: CustomEvent) => {
          showBackground(e.detail.index);
        }) as EventListener);
        
        const saved = localStorage.getItem('selectedBackground');
        if (saved) {
          showBackground(parseInt(saved));
        } else {
          showBackground(0);
        }
      }
      
      function initWakaTabs() {
        document.querySelectorAll('.waka-tab-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            
            document.querySelectorAll('.waka-tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.waka-tab-content').forEach(c => c.classList.remove('active'));
            
            btn.classList.add('active');
            document.getElementById(`tab-${tabId}`)?.classList.add('active');
          });
        });
      }
      
      function initPieChart() {
        const pieCenterText = document.getElementById('pieCenterText');
        const pieCenterTime = document.getElementById('pieCenterTime');
        const pieCenterPercent = document.getElementById('pieCenterPercent');
        const pieTooltip = document.getElementById('pieTooltip');
        const pieChart = document.getElementById('pieChart');
        const pieContainer = document.getElementById('pieContainer');
        
        if (!pieChart || !pieCenterText) return;
        
        const langDataEl = document.getElementById('langData');
        const languages = langDataEl ? JSON.parse(langDataEl.textContent || '[]') : [];
        
        function updatePieCenter(index) {
          if (index >= 0 && index < languages.length) {
            const lang = languages[index];
            pieCenterText.textContent = lang.name;
            pieCenterTime.textContent = lang.text;
            pieCenterPercent.textContent = lang.percent.toFixed(1) + '%';
          }
        }
        
        pieChart.addEventListener('mousemove', (e) => {
          const rect = pieChart.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const x = e.clientX - centerX;
          const y = e.clientY - centerY;
          
          let angle = Math.atan2(y, x) * (180 / Math.PI) + 90;
          if (angle < 0) angle += 360;
          
          let cumulativePercent = 0;
          let hoveredIndex = -1;
          
          for (let i = 0; i < languages.length && i < 8; i++) {
            const startAngle = cumulativePercent * 3.6;
            cumulativePercent += languages[i].percent;
            const endAngle = cumulativePercent * 3.6;
            
            if (angle >= startAngle && angle < endAngle) {
              hoveredIndex = i;
              break;
            }
          }
          
          if (hoveredIndex >= 0) {
            pieTooltip.style.opacity = '1';
            pieTooltip.style.left = `${e.clientX - pieContainer.getBoundingClientRect().left + 10}px`;
            pieTooltip.style.top = `${e.clientY - pieContainer.getBoundingClientRect().top - 10}px`;
            pieTooltip.innerHTML = `
              <div class="tooltip-color" style="background: ${colors[hoveredIndex]}"></div>
              <div class="tooltip-content">
                <div class="tooltip-name">${languages[hoveredIndex].name}</div>
                <div class="tooltip-stats">
                  <span>${languages[hoveredIndex].text}</span>
                  <span class="tooltip-percent">${languages[hoveredIndex].percent.toFixed(1)}%</span>
                </div>
              </div>
            `;
            updatePieCenter(hoveredIndex);
            pieChart.style.transform = 'scale(1.02)';
          }
        });
        
        pieChart.addEventListener('mouseleave', () => {
          pieTooltip.style.opacity = '0';
          pieChart.style.transform = 'scale(1)';
          updatePieCenter(0);
        });
        
        document.querySelectorAll('.pie-legend-item').forEach((item, i) => {
          item.addEventListener('mouseenter', () => {
            updatePieCenter(i);
          });
          item.addEventListener('mouseleave', () => {
            updatePieCenter(0);
          });
        });
      }
      
      document.addEventListener('DOMContentLoaded', () => {
        initWakaTabs();
        initPieChart();
        initMcBackground();
      });
      
      function initMcBackground() {
        const track = document.getElementById('mcScrollTrack');
        const tooltip = document.getElementById('mcTooltip');
        if (!track) return;
        
        const blockSize = 32;
        const gap = 3;
        
        const textures = {
          1: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/grass_block_top.png',
          2: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/emerald_block.png',
          3: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/diamond_block.png',
          4: 'https://cdn.jsdelivr.net/gh/Faithful-Pack/Default-Java@1.21.5/assets/minecraft/textures/block/gold_block.png'
        };
        
        const data = JSON.parse(document.getElementById('contributionData')?.textContent || '[]');
        const laneWidth = data.length * (blockSize + gap);
        
        function createBlocks() {
          const fragment = document.createDocumentFragment();
          
          for (let x = 0; x < data.length; x++) {
            for (let y = 0; y < 7; y++) {
              const day = data[x]?.[y];
              
              if (day && day.count > 0) {
                const block = document.createElement('div');
                block.className = `mc-bg-block level-${day.level}`;
                block.style.left = `${x * (blockSize + gap)}px`;
                block.style.top = `${y * (blockSize + gap)}px`;
                block.dataset.date = day.date;
                block.dataset.count = day.count;
                block.dataset.level = day.level;
                
                const img = document.createElement('img');
                img.src = textures[day.level];
                img.className = 'mc-texture';
                img.alt = '';
                img.draggable = false;
                block.appendChild(img);
                
                block.addEventListener('mouseenter', (e) => {
                  const date = new Date(day.date);
                  const options: Intl.DateTimeFormatOptions = { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' };
                  tooltip.innerHTML = `
                    <div class="mc-tooltip-header">
                      <img src="${textures[day.level]}" class="mc-tooltip-icon" />
                      <div class="mc-tooltip-info">
                        <span class="mc-tooltip-count">${day.count} contribution${day.count !== 1 ? 's' : ''}</span>
                        <span class="mc-tooltip-date">${date.toLocaleDateString('en-US', options)}</span>
                      </div>
                    </div>
                  `;
                  tooltip.style.opacity = '1';
                  tooltip.style.left = `${e.clientX + 15}px`;
                  tooltip.style.top = `${e.clientY + 15}px`;
                });
                
                block.addEventListener('mousemove', (e) => {
                  tooltip.style.left = `${e.clientX + 15}px`;
                  tooltip.style.top = `${e.clientY + 15}px`;
                });
                
                block.addEventListener('mouseleave', () => {
                  tooltip.style.opacity = '0';
                });
                
                fragment.appendChild(block);
              }
            }
          }
          
          return fragment;
        }
        
        track.innerHTML = '';
        
        const lane1 = document.createElement('div');
        lane1.className = 'mc-scroll-lane';
        lane1.style.left = '0px';
        lane1.appendChild(createBlocks());
        
        const lane2 = document.createElement('div');
        lane2.className = 'mc-scroll-lane';
        lane2.style.left = `${laneWidth}px`;
        lane2.appendChild(createBlocks());
        
        track.appendChild(lane1);
        track.appendChild(lane2);
        
        track.style.width = `${laneWidth * 2}px`;
        track.style.setProperty('--lane-width', `${laneWidth}px`);
        
        track.classList.add('mc-scroll-animated');
      }
    </script>
  </body>
</html>
