          <rect x="8" y="1" width="2" height="2" fill="#222" opacity="0.9"/>
          <rect x="11" y="1" width="4" height="2" fill="#444" opacity="0.7"/>
          <rect x="1" y="4" width="4" height="2" fill="#666" opacity="0.5"/>
          <rect x="6" y="4" width="2" height="2" fill="#333" opacity="0.8"/>
          <rect x="9" y="4" width="3" height="2" fill="#555" opacity="0.6"/>
