      <button class="bg-btn" data-bg="9" title="Falling Blocks">
        <svg viewBox="0 0 16 16">
          <rect x="2" y="2" width="5" height="5" fill="#4ade80" opacity="0.8" transform="rotate(15 4.5 4.5)"/>
          <rect x="9" y="5" width="5" height="5" fill="#3b82f6" opacity="0.8" transform="rotate(-10 11.5 7.5)"/>
