---
import "../styles/global.css";

interface Repo {
  name: string;
  description: string;
  language: string;
  stars: number;
  url: string;
  color: string;
}

interface ContributionDay {
  date: string;
  count: number;
  level: number;
}

interface WakaStatItem {
  name: string;
  total_seconds: number;
  percent: number;
  digital: string;
  text: string;
  hours: number;
  minutes: number;
}

interface WakaStatsData {
  human_readable_range: string;
  human_readable_total: string;
  human_readable_daily_average: string;
  human_readable_total_including_other_language: string;
  total_seconds: number;
  total_seconds_including_other_language: number;
  daily_average: number;
  days_minus_holidays: number;
  best_day: { date: string; text: string; total_seconds: number } | null;
  languages: WakaStatItem[];
  editors: WakaStatItem[];
  operating_systems: WakaStatItem[];
  categories: WakaStatItem[];
}

interface WakaAllTimeData {
  text: string;
  digital: string;
  daily_average: number;
  range: { start_date: string };
  total_seconds: number;
}

interface StarredRepo {
  name: string;
  description: string | null;
  language: string | null;
  stars: number;
  url: string;
}

const colorMap: Record<string, string> = {
  Java: "#ea580c",
  Python: "#eab308",
  JavaScript: "#eab308",
  TypeScript: "#3b82f6",
  Dart: "#06b6d4",
  GDScript: "#059669",
  Lua: "#000080",
  HTML: "#e34c26",
  CSS: "#563d7c",
  Shell: "#89e051",
  Rust: "#dea584",
  Go: "#00add8",
  C: "#555555",
  "C++": "#f34b7d",
  Kotlin: "#a97bff",
  Swift: "#ffac45",
};

const res = await fetch(
  "https://api.github.com/users/crazygiscool/repos?sort=stars&per_page=100",
);
const repos: Repo[] = (await res.json())
  .filter((r: any) => !r.fork && r.description)
  .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count)
  .slice(0, 6)
  .map((r: any) => ({
    name: r.name,
    description: r.description,
    language: r.language || "Code",
    stars: r.stargazers_count,
    url: r.html_url,
    color: colorMap[r.language] || "#a855f7",
  }));

const contributionsRes = await fetch(
  "https://github-contributions-api.jogruber.de/v4/crazygiscool",
);
const contributions = contributionsRes.ok
  ? await contributionsRes.json()
  : { contributions: [], totalContributions: 0 };

const rawContributions = contributions.contributions || [];

const totalContributions = rawContributions.reduce(
  (sum: number, d: any) => sum + (d.count || 0),
  0,
);

const weeksData: ContributionDay[][] = [];
let currentWeek: ContributionDay[] = [];

rawContributions.forEach((day: any) => {
  const count = day.count || 0;
  let level = 0;
  if (count > 0) {
    if (count <= 2) level = 1;
    else if (count <= 5) level = 2;
    else if (count <= 10) level = 3;
    else level = 4;
  }
  currentWeek.push({ date: day.date, count, level });
  if (currentWeek.length === 7) {
    weeksData.push(currentWeek);
    currentWeek = [];
  }
});
if (currentWeek.length > 0) weeksData.push(currentWeek);

const monthNames = [
  "Jan", "Feb", "Mar", "Apr", "May", "Jun",
  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec",
];
const monthLabels: { month: string; weekIndex: number }[] = [];
let lastMonth = -1;
weeksData.forEach((week, i) => {
  const firstDay = week.find((d) => d !== null);
  if (firstDay?.date) {
    const month = new Date(firstDay.date).getMonth();
    if (month !== lastMonth) {
      monthLabels.push({ month: monthNames[month], weekIndex: i });
      lastMonth = month;
    }
  }
});

const wakaKey = import.meta.env.WAKATIME_API_KEY;
let wakaStats: { data: WakaStatsData } | null = null;
let wakaAllTimeStats: { data: WakaAllTimeData } | null = null;

if (wakaKey) {
  const wakaRes = await fetch(
    "https://wakatime.com/api/v1/users/current/stats/last_7_days",
    { headers: { Authorization: `Basic ${btoa(wakaKey)}` } },
  );
  wakaStats = await wakaRes.json();

  const wakaAllRes = await fetch(
    "https://wakatime.com/api/v1/users/current/all_time_since_today",
    { headers: { Authorization: `Basic ${btoa(wakaKey)}` } },
  );
  wakaAllTimeStats = await wakaAllRes.json();
}

const starredRes = await fetch(
  "https://api.github.com/users/crazygiscool/starred?per_page=30&sort=updated",
);
const starredRepos: StarredRepo[] = starredRes.ok
  ? (await starredRes.json()).slice(0, 6).map((r: any) => ({
      name: r.name,
      description: r.description,
      language: r.language || "Code",
      stars: r.stargazers_count,
      url: r.html_url,
    }))
  : [];

const skills = [
  { name: "Java", level: 85, color: "#ea580c" },
  { name: "GDScript", level: 80, color: "#059669" },
  { name: "Dart", level: 60, color: "#06b6d4" },
  { name: "Python", level: 70, color: "#eab308" },
  { name: "TypeScript", level: 65, color: "#3b82f6" },
  { name: "JavaScript", level: 70, color: "#eab308" },
  { name: "Lua", level: 55, color: "#000080" },
  { name: "Go", level: 45, color: "#00add8" },
];
---

<!doctype html>
<html lang="en" class="bg-bg text-text antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Crazygiscool — Developer & Systems Engineer" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <title>Crazygiscool — Developer & Systems Engineer</title>
  </head>
  <body class="min-h-screen bg-bg text-text">
    <nav class="fixed top-0 left-0 right-0 z-50 h-14 border-b border-border bg-bg/80 backdrop-blur-md">
      <div class="mx-auto flex h-full max-w-6xl items-center justify-between px-6">
        <a href="#" class="font-mono text-sm font-bold tracking-tight text-accent hover:text-accent-hover transition-colors">
          $ whoami
        </a>
        <div class="nav-links flex items-center gap-6 font-mono text-xs text-text-muted">
          <a href="#tech" class="hover:text-accent transition-colors">// tech</a>
          <a href="#projects" class="hover:text-accent transition-colors">// projects</a>
          <a href="#stats" class="hover:text-accent transition-colors">// stats</a>
          <a href="#contact" class="hover:text-accent transition-colors">// contact</a>
        </div>
      </div>
    </nav>

    <main class="pt-14">
      <!-- HERO -->
      <section class="relative mx-auto max-w-6xl px-6 pt-24 pb-20 md:pt-32 md:pb-28">
        <div class="hero-grid grid gap-12 md:grid-cols-[1.3fr_1fr]">
          <div class="animate-fade-in flex flex-col gap-5">
            <span class="font-mono text-xs font-medium tracking-[0.2em] text-accent uppercase">
              Developer & Systems Engineer
            </span>
            <h1 class="font-mono text-4xl font-extrabold leading-tight tracking-tight md:text-5xl lg:text-6xl">
              CRAZY G<span class="text-accent">_</span>
              <span class="animate-blink text-accent-cyan">|</span>
            </h1>
            <div class="flex flex-wrap gap-2">
              <span class="inline-block rounded border border-border bg-surface px-3 py-1 font-mono text-xs text-text-muted">
                $ cat /etc/bio
              </span>
              <span class="inline-block rounded border border-border bg-surface px-3 py-1 font-mono text-xs text-accent-green">
                > Developer passionate about Minecraft plugins, Godot games & systems tooling
              </span>
            </div>
            <div class="flex items-center gap-4 font-mono text-sm">
              <div class="flex items-baseline gap-1.5">
                <span class="text-2xl font-bold text-text">{totalContributions}</span>
                <span class="text-xs text-text-muted">contributions / yr</span>
              </div>
              <div class="flex items-baseline gap-1.5">
                <span class="text-2xl font-bold text-text">{repos.length}</span>
                <span class="text-xs text-text-muted">projects</span>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <a href="https://github.com/crazygiscool" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 font-mono text-xs text-text-muted hover:border-accent hover:text-accent transition-all duration-150">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                <span>github</span>
                <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </a>
              <a href="https://youtube.com/@crazygiscool" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 font-mono text-xs text-text-muted hover:border-accent-pink hover:text-accent-pink transition-all duration-150">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <span>youtube</span>
                <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </a>
              <a href="mailto:crazygiscool@proton.me" class="group inline-flex items-center gap-2 rounded-lg border border-border bg-surface px-4 py-2 font-mono text-xs text-text-muted hover:border-accent-cyan hover:text-accent-cyan transition-all duration-150">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                <span>email</span>
                <span class="opacity-0 group-hover:opacity-100 transition-opacity">→</span>
              </a>
            </div>
          </div>

          <div class="animate-slide-in flex items-start justify-center md:justify-end">
            <div
              id="contributionGraph"
              class="contribution-scroll w-full overflow-x-auto pb-2"
              style="mask-image: linear-gradient(to left, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to left, black 80%, transparent 100%);"
            >
              <div id="graphContainer" class="contribution-grid">
                <script id="contribData" type="application/json" set:html={JSON.stringify(weeksData)}></script>
                <script id="monthLabels" type="application/json" set:html={JSON.stringify(monthLabels)}></script>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- TECH STACK -->
      <section id="tech" class="border-t border-border py-20">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-10 flex items-center gap-3">
            <span class="font-mono text-xs text-accent">01</span>
            <h2 class="font-mono text-sm font-bold tracking-wider uppercase text-text-muted">Tech Stack</h2>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
            {skills.map((skill) => (
              <div
                class="group flex items-center gap-3 rounded-xl border border-border bg-surface p-4 hover:border-[var(--skill-color)]/50 transition-all duration-200"
                style={`--skill-color: ${skill.color}`}
              >
                <div
                  class="h-2.5 w-2.5 shrink-0 rounded-full"
                  style={`background: ${skill.color}`}
                ></div>
                <div class="flex flex-1 items-center justify-between">
                  <span class="font-mono text-sm font-medium text-text">{skill.name}</span>
                  <span class="font-mono text-xs text-text-dim">{skill.level}%</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- PROJECTS -->
      <section id="projects" class="border-t border-border py-20">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-10 flex items-center gap-3">
            <span class="font-mono text-xs text-accent">02</span>
            <h2 class="font-mono text-sm font-bold tracking-wider uppercase text-text-muted">Projects</h2>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {repos.map((project) => (
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex flex-col rounded-xl border border-border bg-surface p-5 hover:border-accent/40 hover:-translate-y-0.5 transition-all duration-200"
              >
                <div class="mb-3 flex items-center gap-2.5">
                  <span
                    class="h-2.5 w-2.5 shrink-0 rounded-full"
                    style={`background: ${project.color}`}
                  ></span>
                  <span class="flex-1 truncate font-mono text-sm font-semibold text-text group-hover:text-accent transition-colors">
                    {project.name}
                  </span>
                  {project.stars > 0 && (
                    <span class="font-mono text-xs text-text-dim">&starf; {project.stars}</span>
                  )}
                </div>
                <p class="mb-4 flex-1 text-sm leading-relaxed text-text-muted">
                  {project.description}
                </p>
                <div class="mt-auto flex items-center justify-between">
                  <span
                    class="inline-block rounded-full border border-border px-2.5 py-0.5 font-mono text-[11px] text-text-muted"
                  >
                    {project.language}
                  </span>
                  <span class="font-mono text-xs text-text-dim opacity-0 group-hover:opacity-100 transition-opacity">
                    View Source →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- WAKATIME SYSTEM STATS -->
      {wakaStats && wakaStats.data && (
        <section id="stats" class="border-t border-border py-20">
          <div class="mx-auto max-w-6xl px-6">
            <div class="mb-10 flex items-center gap-3">
              <span class="font-mono text-xs text-accent">03</span>
              <h2 class="font-mono text-sm font-bold tracking-wider uppercase text-text-muted">System Stats</h2>
              <div class="h-px flex-1 bg-border"></div>
            </div>

            <!-- Terminal-style summary -->
            <div class="mb-8 overflow-hidden rounded-xl border border-border bg-surface font-mono text-sm">
              <div class="flex items-center gap-2 border-b border-border bg-bg-alt px-4 py-2.5">
                <span class="h-3 w-3 rounded-full bg-danger/70"></span>
                <span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
                <span class="h-3 w-3 rounded-full bg-accent-green/70"></span>
                <span class="ml-2 text-xs text-text-dim">wakatime@stats -- {wakaStats.data.human_readable_range}</span>
              </div>
              <div class="space-y-1.5 p-4 text-xs leading-relaxed text-text-muted">
                <div class="flex gap-2">
                  <span class="text-accent-green">$</span>
                  <span>cat /proc/coding_activity</span>
                </div>
                <div class="flex flex-wrap gap-x-6 gap-y-2 pl-4 text-text">
                  <span>Total: <span class="font-bold text-accent">{wakaStats.data.human_readable_total}</span></span>
                  <span>Daily: <span class="font-bold text-accent-cyan">{wakaStats.data.human_readable_daily_average}</span></span>
                  <span>Active: <span class="font-bold text-accent-green">{wakaStats.data.days_minus_holidays}d</span></span>
                  <span>Best: <span class="font-bold text-accent-pink">{wakaStats.data.best_day?.text || '-'}</span></span>
                </div>
                {wakaAllTimeStats?.data && (
                  <div class="flex gap-2 pt-0.5">
                    <span class="text-accent-green">$</span>
                    <span>cat /proc/all_time_coding</span>
                  </div>
                )}
                {wakaAllTimeStats?.data && (
                  <div class="flex flex-wrap gap-x-6 gap-y-2 pl-4 text-text">
                    <span>All time: <span class="font-bold text-accent">{wakaAllTimeStats.data.text}</span></span>
                    <span>Daily avg: <span class="font-bold text-accent-cyan">{Math.round((wakaAllTimeStats.data.daily_average || 0) / 3600 * 10) / 10}h</span></span>
                    <span>Since: <span class="font-bold text-text-muted">{wakaAllTimeStats.data.range.start_date}</span></span>
                  </div>
                )}
              </div>
            </div>

            <!-- Tabs -->
            <div class="waka-tabs">
              <div class="mb-5 flex flex-wrap gap-2">
                <button class="waka-tab-btn active rounded-lg border border-accent/30 bg-accent/10 px-3.5 py-2 font-mono text-xs font-medium text-accent hover:bg-accent/20" data-tab="languages">Languages</button>
                <button class="waka-tab-btn rounded-lg border border-border bg-surface px-3.5 py-2 font-mono text-xs font-medium text-text-muted hover:border-accent/30 hover:text-accent" data-tab="editors">Editors</button>
                <button class="waka-tab-btn rounded-lg border border-border bg-surface px-3.5 py-2 font-mono text-xs font-medium text-text-muted hover:border-accent/30 hover:text-accent" data-tab="os">OS</button>
                <button class="waka-tab-btn rounded-lg border border-border bg-surface px-3.5 py-2 font-mono text-xs font-medium text-text-muted hover:border-accent/30 hover:text-accent" data-tab="categories">Categories</button>
              </div>

              <div class="waka-tab-content active" id="tab-languages">
                <div class="rounded-xl border border-border bg-surface p-6">
                  <script id="langData" type="application/json" set:html={JSON.stringify(wakaStats.data.languages.slice(0, 8))}></script>
                  <div class="flex flex-col items-center gap-8 md:flex-row md:items-start">
                    <div class="relative flex items-center justify-center" id="pieContainer">
                      <div
                        id="pieChart"
                        class="h-60 w-60 rounded-full shadow-lg shadow-accent/10 cursor-pointer transition-transform duration-200 hover:scale-[1.02]"
                        style={(() => {
                          const topLangs = wakaStats.data.languages.slice(0, 8);
                          const colors = ["#7c3aed", "#ec4899", "#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#06b6d4", "#8b5cf6"];
                          let gradient = "";
                          let currentDeg = 0;
                          topLangs.forEach((lang, i) => {
                            const deg = (lang.percent / 100) * 360;
                            gradient += `${colors[i % colors.length]} ${currentDeg}deg ${currentDeg + deg}deg, `;
                            currentDeg += deg;
                          });
                          return `background: conic-gradient(${gradient.slice(0, -2)});`;
                        })()}
                      >
                        <div class="absolute inset-8 flex flex-col items-center justify-center rounded-full bg-bg text-center">
                          <span class="font-mono text-sm font-bold text-text" id="pieCenterText">{wakaStats.data.languages[0]?.name || '-'}</span>
                          <span class="font-mono text-xs text-text-muted" id="pieCenterTime">{wakaStats.data.languages[0]?.text || '-'}</span>
                          <span class="font-mono text-sm font-semibold text-accent" id="pieCenterPercent">{wakaStats.data.languages[0]?.percent.toFixed(1) || '0'}%</span>
                        </div>
                      </div>
                      <div id="pieTooltip" class="pointer-events-none absolute z-10 min-w-[160px] rounded-lg border border-accent/50 bg-bg/95 p-3 text-xs opacity-0 shadow-xl backdrop-blur-sm transition-opacity duration-150" style="box-shadow: 0 4px 20px rgba(0,0,0,0.5);"></div>
                    </div>
                    <div class="flex flex-wrap justify-center gap-2 md:flex-1 md:justify-start md:self-center">
                      {wakaStats.data.languages.slice(0, 8).map((lang, i) => {
                        const colors = ["#7c3aed", "#ec4899", "#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#06b6d4", "#8b5cf6"];
                        return (
                          <div class="pie-legend-item flex cursor-pointer items-center gap-2 rounded-md px-2.5 py-1.5 text-xs transition-colors hover:bg-accent/10" data-index={i}>
                            <span class="h-2.5 w-2.5 shrink-0 rounded-full" style={`background: ${colors[i % colors.length]}`}></span>
                            <span class="font-mono text-text-muted">{lang.name}</span>
                            <span class="font-mono text-text-dim">{lang.percent.toFixed(1)}%</span>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>
              </div>

              <div class="waka-tab-content" id="tab-editors">
                <div class="rounded-xl border border-border bg-surface p-6">
                  {wakaStats.data.editors && wakaStats.data.editors.length > 0 ? (
                    <div class="grid gap-4 sm:grid-cols-2">
                      {wakaStats.data.editors.map((editor, i) => {
                        const colors = ["#7c3aed", "#ec4899", "#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#06b6d4", "#8b5cf6"];
                        return (
                          <div class="waka-block rounded-lg border border-border bg-surface-alt p-4">
                            <div class="mb-2 flex items-center justify-between">
                              <span class="font-mono text-sm font-medium text-text">{editor.name}</span>
                              <span class="font-mono text-xs text-text-muted">{editor.percent.toFixed(1)}%</span>
                            </div>
                            <div class="mb-2 h-1.5 overflow-hidden rounded-full bg-border">
