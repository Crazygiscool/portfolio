                  rel="noopener noreferrer"
                  class="group flex flex-col rounded-xl border border-border bg-surface p-4 hover:border-accent/40 hover:-translate-y-0.5 transition-all duration-200"
                >
                  <div class="mb-2 flex items-center gap-2">
                    <span class="flex-1 truncate font-mono text-sm font-medium text-text group-hover:text-accent transition-colors">
                      {repo.name}
                    </span>
                    <span class="shrink-0 font-mono text-xs text-text-dim">&starf; {repo.stars}</span>
                  </div>
                  <p class="mb-3 flex-1 text-xs leading-relaxed text-text-muted">
                    {repo.description || 'No description'}
                  </p>
                  <span class="inline-block self-start rounded-full border border-border px-2 py-0.5 font-mono text-[11px] text-text-muted">
                    {repo.language || 'Code'}
