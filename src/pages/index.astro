                            <div class="mb-2 h-1.5 overflow-hidden rounded-full bg-border">
                              <div class="h-full rounded-full transition-all" style={`width: ${cat.percent}%; background: ${colors[i % colors.length]}`}></div>
                            </div>
                            <span class="font-mono text-xs text-text-dim">{cat.text}</span>
                          </div>
                        );
                      })}
                    </div>
                  ) : (
                    <p class="font-mono text-xs text-text-muted">No category data</p>
                  )}
                </div>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- STARRED REPOS -->
      <section class="border-t border-border py-20">
        <div class="mx-auto max-w-6xl px-6">
          <div class="mb-10 flex items-center gap-3">
            <span class="font-mono text-xs text-accent">04</span>
            <h2 class="font-mono text-sm font-bold tracking-wider uppercase text-text-muted">Starred Repos</h2>
            <div class="h-px flex-1 bg-border"></div>
          </div>
          {starredRepos.length > 0 ? (
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {starredRepos.map((repo) => (
                <a
                  href={repo.url}
