          <path d="M0 8 Q4 4, 8 8 T16 8" stroke="#a855f7" stroke-width="2" fill="none" opacity="0.4"/>
          <path d="M0 10 Q4 6, 8 10 T16 10" stroke="#3b82f6" stroke-width="2" fill="none" opacity="0.3"/>
