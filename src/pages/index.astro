                              <span class="font-mono text-sm font-medium text-text">{os.name}</span>
                              <span class="font-mono text-xs text-text-muted">{os.percent.toFixed(1)}%</span>
                            </div>
                            <div class="mb-2 h-1.5 overflow-hidden rounded-full bg-border">
                              <div class="h-full rounded-full transition-all" style={`width: ${os.percent}%; background: ${colors[i % colors.length]}`}></div>
