    <main>
      <section class="hero">
        <div class="hero-background">
          <div id="backgroundContainer">
            <div class="bg-layer active" id="bg-0">
              <div class="background-container" id="fireflies-container">
                <canvas id="fireflies-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-1">
              <div class="background-container" id="matrix-container">
                <canvas id="matrix-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-2">
              <div class="background-container" id="starfield-container">
                <canvas id="starfield-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-3">
              <div class="gradient-waves">
                <div class="wave wave1"></div>
                <div class="wave wave2"></div>
                <div class="wave wave3"></div>
                <div class="wave wave4"></div>
              </div>
            </div>
            <div class="bg-layer" id="bg-4">
              <div class="background-container" id="mc-terrain-container">
                <canvas id="mc-terrain-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-5">
              <div class="background-container" id="coderain-container">
                <canvas id="coderain-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-6">
              <div class="background-container" id="blobs-container">
                <canvas id="blobs-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-7">
              <div class="background-container" id="noise-container">
                <canvas id="noise-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-8">
              <div class="background-container" id="aurora-container">
                <canvas id="aurora-canvas"></canvas>
              </div>
            </div>
            <div class="bg-layer" id="bg-9">
              <div class="background-container" id="falling-blocks-container">
                <canvas id="falling-blocks-canvas"></canvas>
              </div>
            </div>
          </div>
          <div class="mc-background" id="mcBackground">
            <div class="mc-scroll-track" id="mcScrollTrack"></div>
          </div>
          <div class="mc-tooltip" id="mcTooltip"></div>
        </div>
        <script id="contributionData" type="application/json" set:html={JSON.stringify(displayWeeks)}></script>
        
        <div class="hero-content">
          <p class="hero-greeting">Hello There!</p>
          <h1>I am <span>Crazygiscool</span></h1>
          <p class="hero-bio">Developer passionate about Minecraft plugins, Godot games, and building useful tools.</p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-value">{thisYearContributions}</span>
              <span class="hero-stat-label">contributions this year</span>
            </div>
          </div>
          <div class="hero-buttons">
            <a href="https://github.com/crazygiscool" class="btn btn-primary">GitHub</a>
            <a href="#projects" class="btn btn-secondary">View Projects</a>
          </div>
        </div>
      </section>

      <section id="projects" class="section">
        <div class="container">
          <h2>Projects</h2>
          <p class="section-subtitle">Things I've built</p>
          <div class="projects-grid">
            {projects.map((project) => (
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card">
                <div class="project-header">
                  <span class="project-dot" style={`background: ${project.color}`}></span>
                  <span class="project-name">{project.name}</span>
                  {project.stars > 0 && <span class="project-stars">★ {project.stars}</span>}
                </div>
                <p class="project-desc">{project.description}</p>
                <span class="project-lang">{project.language}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <section id="starred" class="section section-alt">
        <div class="container">
          <h2>Starred Repos</h2>
          <p class="section-subtitle">Recently starred</p>
          {starredRepos.length > 0 ? (
            <div class="projects-grid">
              {starredRepos.slice(0, 6).map((repo: any) => (
                <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="project-card">
                  <div class="project-header">
                    <span class="project-name">{repo.name}</span>
                    <span class="project-stars">★ {repo.stargazers_count}</span>
                  </div>
                  <p class="project-desc">{repo.description || 'No description'}</p>
                  <span class="project-lang">{repo.language || 'Code'}</span>
                </a>
              ))}
            </div>
          ) : (
            <p class="text-center text-gray-500">No starred repositories</p>
          )}
