    <script>
      // Contribution graph
      (function initContributionGraph() {
        const dataEl = document.getElementById("contribData");
        const monthEl = document.getElementById("monthLabels");
        const container = document.getElementById("graphContainer");
        if (!dataEl || !container) return;

        const weeks = JSON.parse(dataEl.textContent || "[]");
        const months = monthEl ? JSON.parse(monthEl.textContent || "[]") : [];

        const wrapper = document.createElement("div");
        wrapper.className = "contribution-grid";

        months.forEach((m) => {
          const label = document.createElement("div");
          label.className = "font-mono text-[10px] text-text-dim";
          label.style.cssText = `position: absolute; left: ${m.weekIndex * 13 + 44}px; top: -16px;`;
          label.textContent = m.month;
          container.appendChild(label);
        });

        weeks.forEach((week) => {
          const col = document.createElement("div");
          col.className = "contribution-week";
          week.forEach((day) => {
            const block = document.createElement("div");
            block.className = `contribution-day level-${day.level}`;
            block.title = `${day.date}: ${day.count} contributions`;
            col.appendChild(block);
          });
          wrapper.appendChild(col);
        });

        container.appendChild(wrapper);
      })();

      // WakaTime tabs
      (function initWakaTabs() {
        document.querySelectorAll(".waka-tab-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const tabId = btn.getAttribute("data-tab");
            document
              .querySelectorAll(".waka-tab-btn")
              .forEach((b) => {
                b.className =
                  "waka-tab-btn rounded-lg border border-border bg-surface px-3.5 py-2 font-mono text-xs font-medium text-text-muted hover:border-accent/30 hover:text-accent";
              });
            btn.className =
              "waka-tab-btn active rounded-lg border border-accent/30 bg-accent/10 px-3.5 py-2 font-mono text-xs font-medium text-accent hover:bg-accent/20";
            document
              .querySelectorAll(".waka-tab-content")
              .forEach((c) => c.classList.remove("active"));
            document.getElementById(`tab-${tabId}`)?.classList.add("active");
          });
        });
      })();

      // Pie chart interactions
      (function initPieChart() {
        const pieCenterText = document.getElementById("pieCenterText");
        const pieCenterTime = document.getElementById("pieCenterTime");
        const pieCenterPercent = document.getElementById("pieCenterPercent");
        const pieTooltip = document.getElementById("pieTooltip");
        const pieChart = document.getElementById("pieChart");
        const pieContainer = document.getElementById("pieContainer");

        if (!pieChart || !pieCenterText) return;

        const langDataEl = document.getElementById("langData");
        const languages = langDataEl ? JSON.parse(langDataEl.textContent || "[]") : [];
        const colors = ["#7c3aed", "#ec4899", "#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#06b6d4", "#8b5cf6"];

        function updatePieCenter(index) {
          if (index >= 0 && index < languages.length) {
            const lang = languages[index];
            pieCenterText.textContent = lang.name;
            pieCenterTime.textContent = lang.text;
            pieCenterPercent.textContent = lang.percent.toFixed(1) + "%";
          }
        }

        pieChart.addEventListener("mousemove", (e) => {
          const rect = pieChart.getBoundingClientRect();
          const centerX = rect.left + rect.width / 2;
          const centerY = rect.top + rect.height / 2;
          const x = e.clientX - centerX;
          const y = e.clientY - centerY;
          let angle = Math.atan2(y, x) * (180 / Math.PI) + 90;
          if (angle < 0) angle += 360;

          let cumulativePercent = 0;
          let hoveredIndex = -1;

          for (let i = 0; i < languages.length && i < 8; i++) {
            const startAngle = cumulativePercent * 3.6;
            cumulativePercent += languages[i].percent;
            const endAngle = cumulativePercent * 3.6;
            if (angle >= startAngle && angle < endAngle) {
              hoveredIndex = i;
              break;
            }
          }

          if (hoveredIndex >= 0) {
            pieTooltip.style.opacity = "1";
            pieTooltip.style.left = `${e.clientX - pieContainer.getBoundingClientRect().left + 10}px`;
            pieTooltip.style.top = `${e.clientY - pieContainer.getBoundingClientRect().top - 10}px`;
            pieTooltip.innerHTML = `
              <div class="flex items-start gap-2">
                <div class="h-2.5 w-2.5 shrink-0 mt-0.5 rounded-full" style="background: ${colors[hoveredIndex]}"></div>
                <div>
                  <div class="font-semibold text-text">${languages[hoveredIndex].name}</div>
                  <div class="mt-0.5 flex gap-3 text-text-muted">
                    <span>${languages[hoveredIndex].text}</span>
                    <span class="text-accent font-semibold">${languages[hoveredIndex].percent.toFixed(1)}%</span>
                  </div>
                </div>
              </div>
            `;
            updatePieCenter(hoveredIndex);
            pieChart.style.transform = "scale(1.02)";
          }
        });

        pieChart.addEventListener("mouseleave", () => {
          pieTooltip.style.opacity = "0";
          pieChart.style.transform = "scale(1)";
          updatePieCenter(0);
        });

        document.querySelectorAll(".pie-legend-item").forEach((item, i) => {
          item.addEventListener("mouseenter", () => updatePieCenter(i));
          item.addEventListener("mouseleave", () => updatePieCenter(0));
        });
      })();
    </script>
  </body>
