# Get your API key from https://wakatime.com/settings/api-key
WAKATIME_API_KEY=your_wakatime_api_key_here

# Optional: GitHub personal access token (no scopes needed).
# Raises the API rate limit from 60/hr to 5000/hr so project
# fetching + file trees build reliably. Leave blank to use anonymous access.
GITHUB_TOKEN=
